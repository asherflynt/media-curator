# Connections are now configured in the UI (Settings -> Connections) and stored
# in the database, like other *ARR apps. This file is an OPTIONAL bootstrap:
# fill it in for the very first start, then set the keys in the UI and blank
# these out. A value saved in the UI always wins over the env var.
#
# Rotate the Radarr/Sonarr keys that were shared in chat.
MC_RADARR_URL=
MC_RADARR_KEY=
MC_SONARR_URL=
MC_SONARR_KEY=
